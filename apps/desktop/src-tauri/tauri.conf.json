{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RocketX",
  "version": "0.14.5",
  "identifier": "com.lusipad.rocketx",
  "build": {
    "beforeDevCommand": "pnpm --filter @rcx/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @rcx/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "RocketX",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 640,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
