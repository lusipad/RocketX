{
  "name": "@lusipad/rocketx",
  "version": "0.26.0",
  "description": "RocketX application bridge and manifest SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lusipad/RocketX.git",
    "directory": "packages/app-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
