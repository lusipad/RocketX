{
  "name": "create-rcx-app",
  "version": "0.25.13",
  "description": "Create, validate, and preview RocketX applications",
  "type": "module",
  "bin": {
    "create-rcx-app": "./dist/create-cli.js",
    "rcx-app": "./dist/rcx-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node scripts/copy-templates.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@lusipad/rocketx": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "rocketx",
    "scaffold",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lusipad/RocketX.git",
    "directory": "packages/create-rcx-app"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
