# Rocket.Chat 服务地址
RC_BASE_URL=http://localhost:3000

# 机器人账号的个人访问令牌（我的账户 → 个人访问令牌，需勾选「忽略双重验证」）
RC_AUTH_TOKEN=
RC_USER_ID=

# 未在 webhook URL 里指定 channel 时的默认频道
DEFAULT_CHANNEL=devops

# webhook 校验令牌，ADO 侧 URL 需带 ?token=<同样的值>；留空则不校验（仅限内网）
WEBHOOK_TOKEN=

# 消息发送者别名（如 Azure DevOps）。需要 bot 角色的 message-impersonate 权限，
# 普通账号请留空，否则会报 Not enough permission
RC_ALIAS=

PORT=8377

# ===== 工作台查询代理（可选）=====
# ADO 集合地址，如 http://ado-server:8080/tfs/DefaultCollection
ADO_BASE_URL=
# 只读 PAT（Work Items: Read + Code: Read 即可）
ADO_PAT=
