{
  "name": "rocketchatx",
  "private": true,
  "version": "0.24.2",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "pnpm --filter @rcx/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "bridge": "pnpm --filter @rcx/ado-bridge dev",
    "smoke": "tsx scripts/smoke.ts",
    "spike:rc-offline-contract": "tsx scripts/spike-rc-offline-contract.ts",
    "test:pure": "tsx scripts/test-pure.ts",
    "test:regression": "pnpm --filter @rcx/app-sdk build && tsx --test scripts/regressions/*.test.ts",
    "test:ui": "playwright test",
    "test:ecosystem": "node scripts/test-app-ecosystem.mjs",
    "codex:protocol:generate": "node scripts/codex-protocol.mjs --write",
    "codex:protocol:check": "node scripts/codex-protocol.mjs --check",
    "smoke:codex-app-server": "node scripts/smoke-codex-app-server.mjs",
    "spike:butler-dynamic-tools": "node scripts/spike-butler-dynamic-tools.mjs",
    "measure:memory": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/measure-desktop-memory.ps1",
    "measure:memory:trend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/measure-desktop-memory.ps1 -Samples 31 -IntervalSeconds 60 -MaxPrivateMB 350 -MaxGrowthMB 50 -CsvPath memory-trend.csv",
    "gen:emoji": "tsx scripts/gen-emoji.ts",
    "test:classify": "tsx scripts/test-classify.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "emoji-toolkit": "^10.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0"
  }
}
