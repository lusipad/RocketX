{
  "name": "rocketchatx",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "pnpm --filter @rcx/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "bridge": "pnpm --filter @rcx/ado-bridge dev",
    "smoke": "tsx scripts/smoke.ts",
    "test:pure": "tsx scripts/test-pure.ts",
    "test:regression": "tsx --test scripts/regressions/*.test.ts",
    "measure:memory": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/measure-desktop-memory.ps1",
    "gen:emoji": "tsx scripts/gen-emoji.ts",
    "test:classify": "tsx scripts/test-classify.ts"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "emoji-toolkit": "^10.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0"
  }
}
